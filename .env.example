# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase (Postgres + auth). Required for ingest + app runtime.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma connection string. Use Supabase's POOLER host — the direct
# `db.<ref>.supabase.co` endpoint is IPv6-only on free tier and won't
# resolve from most dev machines. URL-encode any special characters in
# the password (e.g. '@' -> '%40') and always append ?sslmode=require.
#
#   postgresql://postgres.<ref>:<urlenc-password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres?sslmode=require
#
# DATABASE_URL = transaction pooler (port 6543) OR session pooler (5432)
# DIRECT_URL   = session pooler (5432) — required by migrations.
DATABASE_URL=
DIRECT_URL=

# Anthropic — model used for /interpret and /narrate
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Email allowlist (comma-separated). Only these users can access the app.
# Superadmin email cannot be removed from the allowlist.
EPAU_EMAIL_ALLOWLIST=alfonso.dearmas@mpua.gov.gy,
EPAU_SUPERADMIN_EMAIL=alfonso.dearmas@mpua.gov.gy

# Ingest source workbook. Overridable with `npm run ingest -- --file <path>`.
EPAU_WORKBOOK_PATH=/Users/alfonsodearmas/EPAU Sabina/Guyana Key Statistics_06022026 for Donald.xlsx
